# Genesis Forge — environment template. Copy to .env.local (or .env) and fill in.
# Nothing reads process.env directly; all access goes through src/lib/env.ts.

# --- Core ---
DATABASE_URL="postgresql://user:password@localhost:5432/genesis_forge?schema=public"
AUTH_SECRET=""            # generate with: npx auth secret
AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Storage backend selector ---
# "r2" (Cloudflare) or "s3" (AWS). Set "s3" to use the studio's existing S3
# bucket as Clay's storage — enables admin import-by-reference + export.
STORAGE_PROVIDER="r2"

# --- Storage: Cloudflare R2 (Stage 3) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_ENDPOINT=""            # optional; defaults to https://<account>.r2.cloudflarestorage.com

# --- Storage: AWS S3 (the studio's existing asset bucket) ---
# Required when STORAGE_PROVIDER="s3". Powers the admin Import / Export console
# (/admin/assets): browse the bucket, register objects by reference, export.
S3_REGION="us-east-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""            # optional; set only for S3-compatible vendors (MinIO, Wasabi…)
S3_EXPORT_BUCKET=""       # optional default destination for "copy files to S3"

# --- Payments (Stage 7/8) ---
PAYMENTS_PROVIDER="stripe"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""

# --- AI concierge (Stage 6) ---
ANTHROPIC_API_KEY=""
VOYAGE_API_KEY=""

# --- Email: Resend (Stage 8) ---
# Transactional receipts on paid orders. Until both are set, receipts no-op
# (logged, not sent). EMAIL_FROM must be a Resend-verified sender address.
RESEND_API_KEY=""
EMAIL_FROM="Clay by Genesis <receipts@yourdomain.com>"

# --- Rate limiting: Upstash Redis (Stage 9) ---
# Throttles signed-download issuance per user. Until both are set, rate limiting
# is a no-op (downloads still work); a Redis outage also fails open by design.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Course video: YouTube Data API (Stage 10) ---
YOUTUBE_DATA_API_KEY=""
